NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/smart_travel_planner
MONGODB_DNS_SERVERS=1.1.1.1,8.8.8.8
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=30m
REFRESH_JWT_SECRET=replace-with-another-long-random-secret
REFRESH_JWT_EXPIRES_IN=7d

EMAIL_VERIFICATION_EXPIRES_IN_HOURS=24
RESEND_API_KEY=your-resend-api-key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Smart Travel Planner <your-email@gmail.com>"

SERPAPI_KEY=your-serpapi-key
FOURSQUARE_API_KEY=your-foursquare-api-key
REST_COUNTRIES_API_KEY=your-rest-countries-api-key
AIRLABS_API_KEY=your-airlabs-api-key
TRANSPORTAPI_APP_ID=your-transportapi-app-id
TRANSPORTAPI_APP_KEY=your-transportapi-app-key
GEOAPIFY_API_KEY=your_geoapify_api_key_here
OPENROUTESERVICE_API_KEY=your_openrouteservice_api_key_here
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant
LIBRETRANSLATE_BASE_URL=http://127.0.0.1:5001
LIBRETRANSLATE_API_KEY=

SERPAPI_DAILY_LIMIT=100
AIRLABS_DAILY_LIMIT=100
OPEN_METEO_DAILY_LIMIT=500
GEMINI_DAILY_LIMIT=100
GROQ_DAILY_LIMIT=100
LIBRETRANSLATE_DAILY_LIMIT=100
